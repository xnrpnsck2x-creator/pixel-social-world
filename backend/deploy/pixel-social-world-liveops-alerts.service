[Unit]
Description=Pixel Social World LiveOps alert probe
Wants=network-online.target pixel-social-world.service
After=network-online.target pixel-social-world.service

[Service]
Type=oneshot
User=pixelsocial
Group=pixelsocial
WorkingDirectory=/opt/pixel-social-world/backend
EnvironmentFile=/etc/pixel-social-world/backend.env
ExecStart=/opt/pixel-social-world/backend/bin/pixel-social-world-liveops-alert-probe
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
